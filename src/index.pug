extends /layout.pug
include /show_list.pug
include /people_list.pug
include /circus_heading
include /social

block content
  .home
    img.logo(src="/images/improv-circus.png", alt=site.title)

    .about-hero
      div=site.description

      .follow
        +social_list(site.social)

    h1.text-shadow
      a.anchor(id='shows')
      | ~ Shows ~
    +show_list(shows, 5)

    h1.text-shadow
      a.anchor(id='players')
      | ~ Players ~

    +people_list
