include card
include theater_info

mixin show_card(show)
  - const showType = show_types[show.type]
  +card('show_card')(data-show-time=show.when)
    h2.card_header: a(href="/shows/" + show.slug, target="_blank")= (show.name || showType.name)
    img.card_image(src="/images/shows/" + (show.image || showType.image), alt=show.name || showType.name)
    .card_right.show_when
      .show_day
      .show_time
    .card_content
      != utils.markdown(show.description || showType.description)
    .card_footer
      +theater_info(show.theater)
