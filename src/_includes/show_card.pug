include card
include theater_info

mixin show_card(show)
  +card('show_card')(
    data-show-time=show.when.iso,
    data-show-tz=show.when.timeZone
    onclick=`window.location.assign('${show.pageLink}')`
    )
    h2.card_header: a(href=show.pageLink)= (show.name)
    img.card_image(src=show.image, alt=show.name)
    .card_right.show_when
      .show_day
      .show_time
    .card_content
      p= show.headline
      if show.tickets
        p.show_active
          +icon('ticket-perforated')
          | &nbsp;
          = show.tickets.description
    .card_footer
      +theater_info(show.theater)
