include theater_logo
include social

mixin person_card(person)
  .card.person_card
    img.person_image(alt=person.name, src='/images/people/' + (person.image || 'default.png'))

    h2.person_name= person.nickname || person.name.split(' ')[0]

    if person.social || person.theaters
      .person_links
        if person.social
          .link_group
            +social_list(person.social)

        if person.theaters
          .link_group
            each theater in person.theaters
              +theater_logo(theater, size='small')

    if person.bio
      .person_content!= person.bio
