include theater_logo
include social

mixin person_card(person)
  .card.person_card
    if person.image
      img.person_image(alt=person.name, src='/images/people/' + person.image)

    h2.person_name= person.name

    if person.location || person.social
      .person_links
        if person.social
          .link_group
            +social_list(person.social)

        if person.theaters
          .link_group
            each theater in person.theaters
              +theater_logo(theater, size='small')

        if person.location
          .link_group= person.location

    if person.bio
      .person_content= person.bio
