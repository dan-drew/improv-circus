mixin show_tickets(show, showOver=true)
  .show_tickets
    if show.ticketInfo.link
      a.tickets.show_active(href=show.ticketInfo.link)
        | Buy Tickets
    else
      .tickets.show_active
        | Tickets coming soon!

    if showOver
      a.tickets.show_past(href='/#shows')
        | This show is over
        br
        | Click for more shows!
    else
      .tickets.show_past
        | This show is over
