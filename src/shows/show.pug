extends /layout
include /theater_info
include /people_list
include /show_tickets

block content
  - const showType = show_types[show.type]
  - const theater = theaters[show.theater]
  - const showImage = utils.image('shows', show.banner_image || showType.banner_image || show.image || showType.image)

  .show_page(data-show-time=show.when)
    .show_image(style=`background-image: url(${showImage})`)
      img.show_image(src=showImage)

    h1= show.name || showType.name

    +theater_info(show.theater)

    .show_when
      .show_day
      .show_time

    +show_tickets(show)

    .show_description
      != utils.markdown(show.description || showType.description)

    .person_gallery
      +people_list(show.players)
