extends /layout
include /theater_info
include /people_list
include /show_tickets
include /meta
include /icon

block title
  =show.title

block meta
  +meta(show)
  script(type="application/ld+json")
    != show.jsonLD(site)

block content
  .show_page(data-show-time=show.when.iso, data-show-tz=show.when.timeZone)
    .show_image(style=`background-image: url("${show.bannerImage}")`)
      img.show_image(src=show.bannerImage)

    h1= show.name

    +theater_info(show.theater)

    .show_when
      .show_day
      .show_time

    +show_tickets(show)

    .show_description
      p: strong= show.headline
      != show.descriptionHtml
      if show.ticketInfo.description
        p.show_active
          +icon('ticket-perforated')
          | &nbsp;
          = show.ticketInfo.description

    +people_list(show.players)
